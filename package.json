{
  "name": "mpb-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "Monitoring cen konkurencji MPB.com (en-eu) → Google Sheets. Headless browser (Playwright) uruchamiany cyklicznie w GitHub Actions.",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node scrape-mpb.js",
    "discover": "MPB_MODE=discover node scrape-mpb.js",
    "refresh": "MPB_MODE=refresh node scrape-mpb.js",
    "selftest": "MPB_MODE=selftest node scrape-mpb.js"
  },
  "dependencies": {
    "googleapis": "^144.0.0",
    "playwright": "^1.47.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
